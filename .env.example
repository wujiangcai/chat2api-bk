# ============================================
# ChatGPT2API 环境变量配置示例
# ============================================

# 认证密钥（必填）
CHATGPT2API_AUTH_KEY=your_secret_key_here

# 基础 URL（可选，用于生成图片 URL）
# CHATGPT2API_BASE_URL=https://your-domain.com

# ============================================
# 商业用户 / 注册 / CDK 配置
# ============================================

# 是否开放邮箱密码注册（默认 true）
# 设为 false / 0 / off 可关闭公开注册，仅保留管理员发放账号/密钥/CDK
REGISTRATION_ENABLED=true

# 同一邮箱/IP 每分钟密码登录尝试次数（默认 8，设为 0 关闭内存限流）
LOGIN_RATE_LIMIT_PER_MINUTE=8

# 同一 IP/密钥前缀每分钟旧版密钥登录尝试次数（默认 12）
KEY_LOGIN_RATE_LIMIT_PER_MINUTE=12

# 同一邮箱/IP 每分钟注册尝试次数（默认 4）
REGISTER_RATE_LIMIT_PER_MINUTE=4

# 同一用户/IP 每分钟 CDK 兑换尝试次数（默认 12）
REDEEM_RATE_LIMIT_PER_MINUTE=12

# 限流后端：memory 适合本地单进程；正式多实例请使用 redis。
RATE_LIMIT_BACKEND=memory
# RATE_LIMIT_REDIS_URL=redis://localhost:6379/0
# RATE_LIMIT_REDIS_PREFIX=chatgpt2api:rate_limit

# Web 前端允许跨域访问的 Origin，逗号分隔；生产环境请改成你的域名
WEB_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# 收据/商业主体信息
BUSINESS_LEGAL_NAME=ChatGPT2API
# BUSINESS_TAX_ID=
# BUSINESS_ADDRESS=
BUSINESS_SUPPORT_EMAIL=support@example.com

# ============================================
# 异步图片任务 Worker
# ============================================

# 内置 Worker 轮询间隔秒数。正式多实例/高并发部署时建议替换为 Redis 队列 Worker。
IMAGE_JOB_WORKER_INTERVAL_SECONDS=1
# 任务失败重试次数上限、重试延迟、运行中任务卡死自动恢复阈值
IMAGE_JOB_MAX_ATTEMPTS=1
IMAGE_JOB_RETRY_DELAY_SECONDS=5
IMAGE_JOB_STALE_RUNNING_SECONDS=900

# 队列/分布式锁后端：storage 使用数据库轮询；redis 使用 Redis 队列 + 分布式锁，适合多实例 Worker
IMAGE_JOB_QUEUE_BACKEND=storage
# REDIS_URL=redis://localhost:6379/0
# IMAGE_JOB_REDIS_QUEUE_KEY=chatgpt2api:image_jobs:queued
# IMAGE_JOB_REDIS_DEAD_LETTER_KEY=chatgpt2api:image_jobs:dead_letter
# IMAGE_JOB_REDIS_LOCK_PREFIX=chatgpt2api:image_jobs:lock:
# IMAGE_JOB_REDIS_LOCK_TTL_SECONDS=900

# ============================================
# 图片资产 / 对象存储
# ============================================

# 当前版本先使用本地对象存储 data/assets；生产环境后续可替换为 S3/R2/MinIO。
OBJECT_STORAGE_BACKEND=local

# S3/R2/MinIO 配置（OBJECT_STORAGE_BACKEND=s3/r2/minio 时启用；需要安装 boto3）
# OBJECT_STORAGE_BUCKET=your-bucket
# OBJECT_STORAGE_ENDPOINT=https://s3.example.com
# OBJECT_STORAGE_REGION=auto
# OBJECT_STORAGE_ACCESS_KEY_ID=your-access-key
# OBJECT_STORAGE_SECRET_ACCESS_KEY=your-secret-key
# OBJECT_STORAGE_PUBLIC_BASE_URL=https://cdn.example.com
# OBJECT_STORAGE_PREFIX=prod
# OBJECT_STORAGE_ACL=public-read

# ============================================
# 存储后端配置
# ============================================

# 存储后端类型（可选值: json, sqlite, postgres, git）
# 默认: json
STORAGE_BACKEND=json

# ============================================
# 数据库配置（当 STORAGE_BACKEND=sqlite/postgres 时使用）
# ============================================

# PostgreSQL 示例
# DATABASE_URL=postgresql://user:password@localhost:5432/chatgpt2api

# Supabase 示例
# DATABASE_URL=postgresql://postgres.xxx:password@aws-1-us-west-1.pooler.supabase.com:5432/postgres

# SQLite 示例（不指定时自动使用 data/accounts.db）
# DATABASE_URL=sqlite:///app/data/accounts.db

# ============================================
# Git 仓库配置（当 STORAGE_BACKEND=git 时使用）
# ============================================

# Git 仓库地址（必填）
# GIT_REPO_URL=https://github.com/your-username/your-private-repo.git

# Git 访问令牌（必填）
# GitHub: ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GitLab: glpat-xxxxxxxxxxxxxxxxxxxx
# GIT_TOKEN=your_git_token_here

# Git 分支（可选，默认: main）
# GIT_BRANCH=main

# Git 仓库中的文件路径（可选，默认: accounts.json）
# GIT_FILE_PATH=accounts.json

# ============================================
# 备份配置（供 scripts/backup_data.py 和系统计划任务使用）
# ============================================

# BACKUP_OUTPUT_DIR=data/backups
# BACKUP_INCLUDE_ASSETS=true
# BACKUP_RETENTION_DAYS=30



# ============================================
# ?????CORS / HTTPS / HSTS / ?????
# ============================================

# ???????? APP_ENV=production???? WEB_ALLOWED_ORIGINS ??????? localhost?
APP_ENV=development
# ???????????????????????https://img.example.com,https://api.example.com
# WEB_ALLOWED_ORIGINS=https://img.example.com
# ??????????X-Frame-Options?CSP?Referrer-Policy?Permissions-Policy ??
SECURITY_HEADERS_ENABLED=true
# ???? HTTP ???? HTTPS???????????? X-Forwarded-Proto?
FORCE_HTTPS=false
# ???? Strict-Transport-Security?????? CHATGPT2API_BASE_URL=https:// ??????
# ENABLE_HSTS=true
HSTS_MAX_AGE_SECONDS=31536000
# ???????? CSP????????? Next.js ?????
# CONTENT_SECURITY_POLICY=default-src 'self'; object-src 'none'; frame-ancestors 'none'

# ============================================
# ????????/health/ready?/api/admin/metrics?/api/admin/alerts?
# ============================================

# ?????????????? warning??? 0 ????
ALERT_JOB_QUEUE_BACKLOG_THRESHOLD=100
# Dead-letter ?????????? warning??? 0 ????
ALERT_DEAD_LETTER_THRESHOLD=1
# running ???????????????? IMAGE_JOB_STALE_RUNNING_SECONDS?
ALERT_RUNNING_JOB_STALE_SECONDS=900
# data ???????? MB ??? critical??? 0 ????
ALERT_DISK_FREE_MB=512
# ????????????????? warning??? 0 ?????
ALERT_BACKUP_MAX_AGE_HOURS=0
# Support ticket SLA overdue alert thresholds; set 0 to disable.
ALERT_SUPPORT_RESPONSE_OVERDUE_THRESHOLD=1
ALERT_SUPPORT_RESOLUTION_OVERDUE_THRESHOLD=1

# ============================================
# Auth / HttpOnly Cookie session / email verification / password reset
# ============================================

REGISTRATION_ENABLED=true
EMAIL_VERIFICATION_REQUIRED=false
AUTH_SESSION_COOKIE_ENABLED=true
AUTH_SESSION_COOKIE_NAME=chatgpt2api_session
AUTH_SESSION_COOKIE_TTL_SECONDS=2592000
# AUTH_SESSION_COOKIE_SECURE=true
AUTH_SESSION_COOKIE_SAMESITE=lax
# Keep true only for backward compatibility; production can set false to rely on HttpOnly cookies.
# AUTH_RESPONSE_INCLUDE_TOKEN=false
# Development can set true to show email verification/password-reset tokens without an email sender.
# AUTH_RETURN_ACTION_TOKENS=false

# Email delivery for verification/password-reset links.
# console logs email content for local development; production should use smtp or resend.
EMAIL_PROVIDER=console
# Public URL used in email action links, for example https://img.example.com
# APP_PUBLIC_URL=
EMAIL_FROM="ChatGPT2API <no-reply@example.com>"
# Enable outbound support-ticket emails for ticket creation, admin replies and status changes.
SUPPORT_TICKET_EMAIL_NOTIFICATIONS_ENABLED=false
SUPPORT_TICKET_EMAIL_SUBJECT_PREFIX="[ChatGPT2API Support]"
# Support-ticket attachment upload limits. Files are stored in the configured object storage backend.
SUPPORT_TICKET_ATTACHMENT_MAX_BYTES=5242880
SUPPORT_TICKET_ATTACHMENT_ALLOWED_TYPES=image/png,image/jpeg,image/webp,application/pdf,text/plain
# SLA windows by priority can be overridden globally or per priority.
# SUPPORT_TICKET_RESPONSE_SLA_HOURS=24
# SUPPORT_TICKET_RESPONSE_SLA_HOURS_URGENT=4
# SUPPORT_TICKET_RESPONSE_SLA_HOURS_HIGH=8
# SUPPORT_TICKET_RESPONSE_SLA_HOURS_LOW=72
# SUPPORT_TICKET_RESOLUTION_SLA_HOURS=96
# SUPPORT_TICKET_RESOLUTION_SLA_HOURS_URGENT=24
# SUPPORT_TICKET_RESOLUTION_SLA_HOURS_HIGH=48
# SUPPORT_TICKET_RESOLUTION_SLA_HOURS_LOW=168
# SMTP provider (also works with SES SMTP credentials).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false
# Resend HTTPS provider.
# RESEND_API_KEY=

# ============================================
# ????????/api/admin/business-report?
# ============================================

# ??????????????????????????? 0 ?????????
COST_PER_IMAGE_CENTS=0
# ???????????????????????????? CNY?
COST_CURRENCY=CNY

# ============================================
# ???????? webhook?/api/payments/webhook/{provider}?
# ============================================

# HMAC-SHA256 webhook ?????????????????????
# PAYMENT_WEBHOOK_SECRET=change-me-payment-webhook-secret
# ??????????????????????????? provider ??? stripe/alipay/wechat?
# PAYMENT_WEBHOOK_SECRET_STRIPE=change-me-stripe-webhook-secret
# PAYMENT_WEBHOOK_SECRET_ALIPAY=change-me-alipay-webhook-secret
# PAYMENT_WEBHOOK_SECRET_WECHATPAY=change-me-wechatpay-webhook-secret
# Local replay helper:
# python scripts/payment_webhook_sandbox.py --provider stripe --action paid --order-id ord_xxx --secret "$PAYMENT_WEBHOOK_SECRET_STRIPE" --base-url http://localhost:8000 --send
# webhook timestamp ?????? 0 ?????????
PAYMENT_WEBHOOK_TOLERANCE_SECONDS=300

# ============================================
# Customer checkout / self-service payment page
# ============================================

# disabled/manual/redirect/stripe
# manual: return operator instructions or an external payment URL.
# redirect: sign and redirect to your own payment aggregator/page; payment is still confirmed by webhook.
# stripe: create Stripe Checkout Sessions through STRIPE_SECRET_KEY.
PAYMENT_CHECKOUT_PROVIDER=manual
# PAYMENT_CHECKOUT_MANUAL_INSTRUCTIONS=请转账后备注订单号 {order_id_raw}，到账后系统会自动或人工确认。
# PAYMENT_CHECKOUT_MANUAL_URL=https://pay.example.com/manual?order={order_id}
# PAYMENT_CHECKOUT_QR_CODE_URL=https://cdn.example.com/pay-qr.png
# PAYMENT_CHECKOUT_URL_TEMPLATE=https://pay.example.com/checkout?order={order_id}&amount={amount_cents}&currency={currency}&sig={signature}&success={success_url}&cancel={cancel_url}
# PAYMENT_CHECKOUT_SIGNING_SECRET=change-me-checkout-signing-secret
# PAYMENT_CHECKOUT_SUCCESS_URL=https://img.example.com/redeem?checkout=success&order_id={order_id}
# PAYMENT_CHECKOUT_CANCEL_URL=https://img.example.com/redeem?checkout=cancel&order_id={order_id}
# STRIPE_SECRET_KEY=sk_live_xxx
# STRIPE_CHECKOUT_API_URL=https://api.stripe.com/v1/checkout/sessions

