# Copy to .env.production and replace every "change-me" value before launch.

APP_ENV=production
CADDY_SITE_ADDRESS=https://img.example.com
ACME_EMAIL=ops@example.com
CHATGPT2API_AUTH_KEY=change-me-long-random-admin-secret
CHATGPT2API_BASE_URL=https://img.example.com
WEB_ALLOWED_ORIGINS=https://img.example.com
BUSINESS_LEGAL_NAME=change-me-company-name
BUSINESS_TAX_ID=
BUSINESS_ADDRESS=
BUSINESS_SUPPORT_EMAIL=support@example.com

# PostgreSQL
STORAGE_BACKEND=postgres
POSTGRES_DB=chatgpt2api
POSTGRES_USER=chatgpt2api
POSTGRES_PASSWORD=change-me-postgres-password
DATABASE_URL=postgresql://chatgpt2api:change-me-postgres-password@postgres:5432/chatgpt2api

# Redis queue and distributed lock
IMAGE_JOB_QUEUE_BACKEND=redis
REDIS_URL=redis://redis:6379/0
IMAGE_JOB_WORKER_INTERVAL_SECONDS=1
IMAGE_JOB_MAX_ATTEMPTS=3
IMAGE_JOB_RETRY_DELAY_SECONDS=10
IMAGE_JOB_STALE_RUNNING_SECONDS=900
IMAGE_SSE_TIMEOUT_SECONDS=180

# Object storage.
# For the bundled single-node MinIO path, Caddy exposes public reads at:
#   https://img.example.com/object-storage/chatgpt2api-assets/<object-key>
# For Cloudflare R2 / AWS S3 / OSS / COS, change endpoint and public base URL.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio-root-password
OBJECT_STORAGE_BACKEND=minio
OBJECT_STORAGE_BUCKET=chatgpt2api-assets
OBJECT_STORAGE_ENDPOINT=http://minio:9000
OBJECT_STORAGE_REGION=auto
OBJECT_STORAGE_ACCESS_KEY_ID=minioadmin
OBJECT_STORAGE_SECRET_ACCESS_KEY=change-me-minio-root-password
OBJECT_STORAGE_PUBLIC_BASE_URL=https://img.example.com/object-storage/chatgpt2api-assets
OBJECT_STORAGE_PREFIX=prod
OBJECT_STORAGE_ACL=

# Public account system
REGISTRATION_ENABLED=true
EMAIL_VERIFICATION_REQUIRED=true
LOGIN_RATE_LIMIT_PER_MINUTE=8
KEY_LOGIN_RATE_LIMIT_PER_MINUTE=12
REGISTER_RATE_LIMIT_PER_MINUTE=4
REDEEM_RATE_LIMIT_PER_MINUTE=12
RATE_LIMIT_BACKEND=redis
RATE_LIMIT_REDIS_URL=redis://redis:6379/0
RATE_LIMIT_REDIS_PREFIX=chatgpt2api:rate_limit
AUTH_SESSION_COOKIE_ENABLED=true
AUTH_SESSION_COOKIE_NAME=chatgpt2api_session
AUTH_SESSION_COOKIE_TTL_SECONDS=2592000
AUTH_SESSION_COOKIE_SECURE=true
AUTH_SESSION_COOKIE_SAMESITE=lax
AUTH_RESPONSE_INCLUDE_TOKEN=false
AUTH_RETURN_ACTION_TOKENS=false

# Email delivery for verification/password-reset links.
APP_PUBLIC_URL=https://img.example.com
EMAIL_PROVIDER=smtp
EMAIL_FROM="ChatGPT2API <no-reply@example.com>"
SUPPORT_TICKET_EMAIL_NOTIFICATIONS_ENABLED=true
SUPPORT_TICKET_EMAIL_SUBJECT_PREFIX="[ChatGPT2API Support]"
SUPPORT_TICKET_ATTACHMENT_MAX_BYTES=5242880
SUPPORT_TICKET_ATTACHMENT_ALLOWED_TYPES=image/png,image/jpeg,image/webp,application/pdf,text/plain
SUPPORT_TICKET_RESPONSE_SLA_HOURS_URGENT=4
SUPPORT_TICKET_RESPONSE_SLA_HOURS_HIGH=8
SUPPORT_TICKET_RESPONSE_SLA_HOURS=24
SUPPORT_TICKET_RESPONSE_SLA_HOURS_LOW=72
SUPPORT_TICKET_RESOLUTION_SLA_HOURS_URGENT=24
SUPPORT_TICKET_RESOLUTION_SLA_HOURS_HIGH=48
SUPPORT_TICKET_RESOLUTION_SLA_HOURS=96
SUPPORT_TICKET_RESOLUTION_SLA_HOURS_LOW=168
SMTP_HOST=change-me-smtp-host
SMTP_PORT=587
SMTP_USERNAME=change-me-smtp-username
SMTP_PASSWORD=change-me-smtp-password
SMTP_USE_TLS=true
SMTP_USE_SSL=false
# Or use Resend instead of SMTP:
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=change-me-resend-api-key

# Security headers and HTTPS. Caddy terminates TLS, so app-side redirect can stay off.
SECURITY_HEADERS_ENABLED=true
FORCE_HTTPS=false
ENABLE_HSTS=true
HSTS_MAX_AGE_SECONDS=31536000
CONTENT_SECURITY_POLICY=

# Backups
BACKUP_OUTPUT_DIR=/app/data/backups
BACKUP_INCLUDE_ASSETS=true
BACKUP_RETENTION_DAYS=30

# Monitoring and alerts
ALERT_JOB_QUEUE_BACKLOG_THRESHOLD=100
ALERT_DEAD_LETTER_THRESHOLD=1
ALERT_RUNNING_JOB_STALE_SECONDS=900
ALERT_DISK_FREE_MB=512
ALERT_BACKUP_MAX_AGE_HOURS=24
ALERT_SUPPORT_RESPONSE_OVERDUE_THRESHOLD=1
ALERT_SUPPORT_RESOLUTION_OVERDUE_THRESHOLD=1

# Business reporting cost estimation
COST_PER_IMAGE_CENTS=0
COST_CURRENCY=CNY

# Signed payment webhooks
PAYMENT_WEBHOOK_SECRET=change-me-payment-webhook-secret
# Optional provider-specific override, where {provider} is the path segment uppercased.
# PAYMENT_WEBHOOK_SECRET_STRIPE=change-me-stripe-webhook-secret
# PAYMENT_WEBHOOK_SECRET_ALIPAY=change-me-alipay-webhook-secret
# PAYMENT_WEBHOOK_SECRET_WECHATPAY=change-me-wechatpay-webhook-secret
PAYMENT_WEBHOOK_TOLERANCE_SECONDS=300

# Customer checkout / self-service payment page.
# Choose redirect for a custom payment aggregator page, or stripe for hosted Stripe Checkout.
PAYMENT_CHECKOUT_PROVIDER=redirect
PAYMENT_CHECKOUT_URL_TEMPLATE=https://pay.example.com/checkout?order={order_id}&amount={amount_cents}&currency={currency}&sig={signature}&success={success_url}&cancel={cancel_url}
PAYMENT_CHECKOUT_SIGNING_SECRET=change-me-checkout-signing-secret
PAYMENT_CHECKOUT_SUCCESS_URL=https://img.example.com/redeem?checkout=success&order_id={order_id}
PAYMENT_CHECKOUT_CANCEL_URL=https://img.example.com/redeem?checkout=cancel&order_id={order_id}
# For Stripe Checkout instead:
# PAYMENT_CHECKOUT_PROVIDER=stripe
# STRIPE_SECRET_KEY=sk_live_xxx
